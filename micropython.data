            "addr": 50,
            "power": [129],
            "vol_up": [17],
            "vol_down": [20],
            "samsung": False,
        },
        "Sony": {
            "protocol": "sony",
            "addr": 1,
            "power": [21],
            "vol_up": [18],
            "vol_down": [19],
        },
        "TCL": {
