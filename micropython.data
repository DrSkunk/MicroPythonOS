    # 0.5~1.2V,10mV/step,71steps
    # 1.22~1.84V,20mV/step,32steps
    def isEnableDC4(self) -> bool:
        return bool(super().getRegisterBit(_AXP2101_DC_ONOFF_DVM_CTRL, 3))

