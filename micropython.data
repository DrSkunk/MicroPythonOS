                version=1,
                max_range="Вұ256 deg/s",
                resolution="0.002 deg/s",
                power_ma=0.7,
            ),
            Sensor(
                name="QMI8658 Temperature",
                sensor_type=TYPE_IMU_TEMPERATURE,
