    def _register_mpu6886_sensors(self):
        self._sensor_list = [
            Sensor(
                name="MPU6886 Accelerometer",
                sensor_type=TYPE_ACCELEROMETER,
                vendor="InvenSense",
                version=1,
                max_range="Вұ16g",
