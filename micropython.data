# SPI_TOUCH_FREQ = const(500_000)
# SPI_TOUCH_FREQ = const(100_000)

EXPANDER_POWER = const(0x40)
LED_GREEN = const(0x49)
LED_BLUE = const(0x4D)  # 13 | 0x40
LED_RED = const(13)

# Power management (known variously as PMU, BMU or just BM):
