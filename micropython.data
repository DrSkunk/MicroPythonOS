LCD_DC = const(47)  # Data Command control pin
LCD_RESET = const(46)

# FIXME: Two backlights? One on the TCA9555 expander, one directly controlled by the ESP32?
LCD_BACKLIGHT = const(2)  # 0x02
BACKLIGHT = const(0x42)

