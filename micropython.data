    lens_facing=CameraManager.CameraCharacteristics.LENS_FACING_FRONT,
    name="Video4Linux2 Camera",
    vendor="ACME",
    init=init_cam,
    deinit=deinit_cam,
    capture=capture_cam,
    apply_settings=apply_cam_settings
))


